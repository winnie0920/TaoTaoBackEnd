<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taotaoapi.mapper.HomeMapper">
    <select id="selectAll" resultType="com.taotaoapi.home.Country">
        SELECT
            id,
            country_key,
            name,
            icon
        FROM _countries
    </select>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taotaoapi.mapper.HomeMapper">
    <select id="selectAllCountry" resultType="com.taotaoapi.home.CountryResponse">
        SELECT
            id,
            country_key AS `key`,
            name,
            icon
        FROM _countries
    </select>

    <select id="selectAllCategory"
            resultType="com.taotaoapi.home.CategoryResponse">
        SELECT
            id,
            categories_key AS `key`,
            name,
            icon
        FROM _categories
    </select>

</mapper>